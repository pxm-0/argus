[Unit]
Description=Argus typed operation agent for %i
After=network.target

[Service]
Type=simple
User=argus-%i
Group=argus-control
WorkingDirectory=/srv/argus
Environment=ARGUS_ROOT=/srv/argus
Environment=ARGUS_RUNTIME=/srv/argus/runtime/argus/m5
Environment=ARGUS_TRUST_DOMAIN=%i
Environment=ARGUS_CAPABILITY_KEY_FILE=/etc/argus/domain-keys/%i.key
ExecStart=/usr/bin/python3 /srv/argus/scripts/argus_domain_agent.py
Restart=on-failure
RestartSec=3
UMask=0007
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
InaccessiblePaths=-/var/run/docker.sock -/run/docker.sock
ReadWritePaths=/srv/argus/runtime/argus -/srv/argus/runtime/audit.log /srv/argus/runtime/backups /srv/argus/config /srv/argus/control-plane/dashboard/public

[Install]
WantedBy=multi-user.target
