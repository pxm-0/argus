#!/usr/bin/env python3
"""Reconcile exact pre-rename M1 projections into the Argus identity."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from argus_m1_identity_reconcile import IdentityReconcileError, reconcile_identity


ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    parser = argparse.ArgumentParser(description="Reconcile audited M1 projections after the Argus identity rename.")
    parser.add_argument("--root", type=Path, default=ROOT)
    parser.add_argument("--apply", action="store_true")
    parser.add_argument("--acknowledge-identity-reconciliation", action="store_true")
    args = parser.parse_args()
    if args.apply and not args.acknowledge_identity_reconciliation:
        raise SystemExit("refusing apply without --acknowledge-identity-reconciliation")
    try:
        print(json.dumps(reconcile_identity(args.root.resolve(), apply=args.apply), sort_keys=True))
    except IdentityReconcileError as exc:
        raise SystemExit(f"Argus identity reconciliation failed: {exc}") from exc
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
