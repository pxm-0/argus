#!/usr/bin/env python3
"""Record the explicit private M0 approval for SSH and Tailscale host ingress."""

from __future__ import annotations

import argparse

from argus_m0 import approve_host_ingress_exceptions, load_private_json, private_path, write_private


def main() -> int:
    parser = argparse.ArgumentParser(description="Approve only the reviewed remote SSH and Tailscale host listener exceptions.")
    parser.add_argument("--acknowledge-remote-ssh", action="store_true")
    parser.add_argument("--acknowledge-tailnet-transport", action="store_true")
    args = parser.parse_args()
    if not args.acknowledge_remote_ssh or not args.acknowledge_tailnet_transport:
        raise SystemExit("refusing: acknowledge both remote SSH and tailnet transport exceptions")
    inventory_path = private_path("legacy-inventory.json")
    plan_path = private_path("remediation-plan.json")
    plan, record = approve_host_ingress_exceptions(
        load_private_json(plan_path), load_private_json(inventory_path), load_private_json(private_path("host-listener-review.json"))
    )
    write_private(plan, plan_path)
    write_private(record, private_path("evidence", "host-ingress-exceptions.json"))
    print("Argus M0 host ingress exceptions approved: remote SSH, tailnet transport")
    print(f"evidence digest: {record['evidenceDigest']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
