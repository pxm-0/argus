#!/usr/bin/env python3
from __future__ import annotations

import argparse

from argus_m1 import privacy_writer
from oreo_common import by_id, load_json, now, print_json, regenerate_dashboard


def main() -> int:
    parser = argparse.ArgumentParser(description="Set an Oreo Cloud workload privacy state.")
    parser.add_argument("workload_id")
    parser.add_argument("privacy")
    parser.add_argument("--reason", default="Operator change")
    parser.add_argument("--json", action="store_true", help="Print the update result as JSON.")
    args = parser.parse_args()
    if args.workload_id not in by_id():
        raise SystemExit(f"unknown workload: {args.workload_id}")
    privacy = load_json("privacy.json")
    if args.privacy not in privacy.get("states", []):
        raise SystemExit(f"invalid privacy state: {args.privacy}")

    old, _ = privacy_writer().set_privacy(workload_id=args.workload_id, privacy_value=args.privacy, reason=args.reason, actor="oreo-privacy-set", timestamp=now())
    regenerate_dashboard(quiet=args.json)

    payload = {"ok": True, "workloadId": args.workload_id, "from": old, "to": args.privacy}
    if args.json:
        print_json(payload)
    else:
        print(f"{args.workload_id} privacy {old} -> {args.privacy}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
