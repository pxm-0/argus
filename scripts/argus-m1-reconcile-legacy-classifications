#!/usr/bin/env python3
"""Reconcile missing explicit M1 legacy quarantine records."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from argus_m1_reconcile import ReconcileError, reconcile


ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    parser = argparse.ArgumentParser(description="Reconcile missing explicit Argus legacy quarantine records.")
    parser.add_argument("--apply", action="store_true")
    parser.add_argument("--acknowledge-quarantine-reconciliation", action="store_true")
    parser.add_argument("--root", type=Path, default=ROOT)
    args = parser.parse_args()
    if args.apply and not args.acknowledge_quarantine_reconciliation:
        raise SystemExit("refusing reconciliation without --acknowledge-quarantine-reconciliation")
    try:
        print(json.dumps(reconcile(args.root.resolve(), apply=args.apply), sort_keys=True))
    except ReconcileError as exc:
        raise SystemExit(f"Argus M1 reconciliation failed: {exc}") from exc
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
