#!/usr/bin/env python3
"""Read-only M4 persistence and isolation verification on oreochiserver."""

from __future__ import annotations

import datetime as dt
import json
import subprocess
import sys
from pathlib import Path

from argus_m4_persistence import evaluate_persistence


ROOT = Path(__file__).resolve().parents[1]
SOCKET = "/var/lib/argus/personal-sandbox/docker.sock"
TARGET_COMPOSE = "/var/lib/argus/personal-sandbox/hello-nginx/docker-compose.json"
SOURCE_COMPOSE = ROOT / "workloads" / "hello-nginx" / "source" / "docker-compose.yml"
SERVICE = "argus-personal-sandbox-rootless-docker.service"
FIREWALL_SERVICE = "argus-personal-sandbox-firewall.service"
CELL_USER = "argus-personal-sandbox"
CUTOVER = dt.datetime(2026, 7, 20, 6, 51, 23, tzinfo=dt.timezone.utc)


def run(*command: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, check=False, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)


def main() -> int:
    uid = run("id", "-u", CELL_USER).stdout.strip()
    user_systemctl = ("runuser", "-u", CELL_USER, "--", "env", f"HOME=/home/{CELL_USER}", f"XDG_RUNTIME_DIR=/run/user/{uid}", "systemctl", "--user")
    target_id = run("docker", "--host", f"unix://{SOCKET}", "compose", "-p", "hello-nginx", "-f", TARGET_COMPOSE, "ps", "-q", "web").stdout.strip()
    inspect = run("docker", "--host", f"unix://{SOCKET}", "inspect", target_id, "--format", "{{.State.Running}}|{{json .HostConfig.PortBindings}}|{{json .Mounts}}") if target_id else None
    fields = inspect.stdout.strip().split("|", 2) if inspect and inspect.returncode == 0 else []
    source = run("docker", "compose", "-p", "hello-nginx", "-f", str(SOURCE_COMPOSE), "ps", "--status", "running", "--services")
    daemon_pid = run("pgrep", "-u", CELL_USER, "-x", "dockerd").stdout.strip().splitlines()
    parent = run("ps", "-o", "ppid=", "-p", daemon_pid[0]) if len(daemon_pid) == 1 else None
    rootless_child_pid = parent.stdout.strip() if parent and parent.returncode == 0 else ""
    listeners = run("nsenter", "-t", rootless_child_pid, "-n", "ss", "-H", "-ltn") if rootless_child_pid else None
    firewall = run("nsenter", "-t", rootless_child_pid, "-n", "nft", "list", "table", "inet", "argus_personal_sandbox") if rootless_child_pid else None
    sandbox_netns = run("readlink", f"/proc/{rootless_child_pid}/ns/net") if rootless_child_pid else None
    host_netns = run("readlink", "/proc/1/ns/net")
    firewall_active = run("systemctl", "is-active", "--quiet", FIREWALL_SERVICE)
    firewall_enabled = run("systemctl", "is-enabled", "--quiet", FIREWALL_SERVICE)
    driver = run("docker", "--host", f"unix://{SOCKET}", "info", "--format", "{{.CgroupDriver}}")
    try:
        boot_epoch = next(int(line.split()[1]) for line in Path("/proc/stat").read_text().splitlines() if line.startswith("btime "))
        booted_after_cutover = boot_epoch > int(CUTOVER.timestamp())
    except (OSError, StopIteration, ValueError, IndexError):
        booted_after_cutover = False
    facts = {
        "daemonActive": run(*user_systemctl, "is-active", "--quiet", SERVICE).returncode == 0,
        "targetRunning": len(fields) == 3 and fields[0] == "true",
        "targetHealthy": bool(target_id) and run("docker", "--host", f"unix://{SOCKET}", "exec", target_id, "nginx", "-t").returncode == 0,
        "sourceFenced": source.returncode == 0 and not source.stdout.strip(),
        "publishedPortsAbsent": len(fields) == 3 and fields[1] in {"{}", "null"},
        "hostMountsAbsent": len(fields) == 3 and fields[2] == "[]",
        "namespaceListenersAbsent": listeners is not None and listeners.returncode == 0 and not listeners.stdout.strip() and firewall is not None and firewall.returncode == 0 and firewall_active.returncode == 0 and firewall_enabled.returncode == 0 and sandbox_netns is not None and sandbox_netns.returncode == 0 and host_netns.returncode == 0 and sandbox_netns.stdout.strip() != host_netns.stdout.strip(),
        "delegationEnabled": driver.returncode == 0 and driver.stdout.strip() == "systemd",
        "cgroupDriverCorrect": driver.returncode == 0 and driver.stdout.strip() == "systemd",
        "hostRebootedAfterCutover": booted_after_cutover,
    }
    result = evaluate_persistence(facts)
    print(json.dumps(result, sort_keys=True))
    return 0 if result["verified"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
