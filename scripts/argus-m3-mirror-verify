#!/usr/bin/env python3
"""Verify the artifact at a no-route mirror and write a bound receipt."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parent))
from argus_portfolio import PortfolioError, validate_mirror

parser = argparse.ArgumentParser()
parser.add_argument("--artifact", type=Path, required=True)
parser.add_argument("--public-key", type=Path, required=True)
parser.add_argument("--receipt", type=Path, required=True)
args = parser.parse_args()
try:
    print(json.dumps(validate_mirror(args.artifact, args.public_key, args.receipt), sort_keys=True))
except PortfolioError as exc:
    print(f"argus-m3-mirror-verify: {exc}", file=sys.stderr)
    raise SystemExit(2)
