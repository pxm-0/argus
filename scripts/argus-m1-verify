#!/usr/bin/env python3
"""Print a secret-safe verification summary for an M1 deployment."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from argus_m1_verify import VerificationError, verify_m1_state


ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    parser = argparse.ArgumentParser(description="Verify deployed Argus M1 private state.")
    parser.add_argument("--root", type=Path, default=ROOT)
    args = parser.parse_args()
    try:
        result = verify_m1_state(args.root.resolve())
    except VerificationError as exc:
        raise SystemExit(f"Argus M1 verification failed: {exc}") from exc
    print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
