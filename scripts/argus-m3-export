#!/usr/bin/env python3
"""Build a signed, static Argus portfolio artifact from an explicit snapshot."""
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).resolve().parent))
from argus_portfolio import PortfolioError, build_artifact

parser = argparse.ArgumentParser()
parser.add_argument("--snapshot", type=Path, required=True)
parser.add_argument("--output", type=Path, required=True)
parser.add_argument("--signing-key", type=Path, required=True)
parser.add_argument("--public-key", type=Path, required=True)
args = parser.parse_args()
try:
    print(json.dumps(build_artifact(json.loads(args.snapshot.read_text()), args.output, args.signing_key, args.public_key), sort_keys=True))
except (OSError, json.JSONDecodeError, PortfolioError) as exc:
    print(f"argus-m3-export: {exc}", file=sys.stderr)
    raise SystemExit(2)
