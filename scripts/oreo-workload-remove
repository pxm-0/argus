#!/usr/bin/env python3
"""Remove a tracked workload's metadata from config/*.json.

Refuses to remove a workload that still has access granted, to avoid
untracking something that is actively exposed. Use --force to override.
"""
from __future__ import annotations

import argparse

from oreo_common import audit, by_id, fail, load_json, save_json


def main() -> int:
    parser = argparse.ArgumentParser(description="Remove a workload from tracked config.")
    parser.add_argument("id")
    parser.add_argument("--force", action="store_true", help="remove even if access is not 'none'")
    args = parser.parse_args()

    workload = by_id().get(args.id)
    if workload is None:
        fail(f"unknown workload: {args.id}")

    access_data = load_json("access.json")
    desired = access_data["workloads"].get(args.id, {}).get("desired", "none")
    if desired != "none" and not args.force:
        fail(f"{args.id} has desired access '{desired}'; reconcile access to 'none' first or pass --force")

    workloads_data = load_json("workloads.json")
    workloads_data["workloads"] = [w for w in workloads_data["workloads"] if w.get("id") != args.id]
    save_json("workloads.json", workloads_data)

    access_data["workloads"].pop(args.id, None)
    save_json("access.json", access_data)

    privacy_data = load_json("privacy.json")
    privacy_data["workloads"].pop(args.id, None)
    save_json("privacy.json", privacy_data)

    audit("workload.remove", args.id, "ok", forced=args.force)
    print(f"Removed {args.id} from tracked workloads.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
