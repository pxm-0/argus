#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path

from oreo_common import print_json, root


SECRET_MARKERS = (
    "BEGIN PRIVATE KEY",
    "Authorization: Bearer",
    "cloudflare_token",
    "password=",
    "token=",
    "secret=",
)
REQUIRED_TEMPLATES = [
    "templates/.gitattributes",
    "templates/.gitignore",
    "templates/AGENTS.md",
    "templates/README.md",
    "templates/caddy/Caddyfile.oreo-cloud.example",
    "templates/cloudflare/cloudflared-config.template.yml",
    "templates/cloudflare/planned-ingress.example.yml",
    "templates/config/access.example.json",
    "templates/config/exposure.example.json",
    "templates/config/monitoring.example.json",
    "templates/config/policy.example.json",
    "templates/config/privacy.example.json",
    "templates/config/routes.example.json",
    "templates/config/workloads.example.json",
    "templates/scripts/bootstrap-layout.sh.example",
    "templates/scripts/discovery.sh.example",
    "templates/systemd/oreo-control-api.service",
    "templates/systemd/oreo-metrics.service",
    "templates/systemd/oreo-metrics.timer",
    "templates/systemd/oreo-smoke.service",
    "templates/systemd/oreo-smoke.timer",
]


def check_json(path: Path) -> str:
    try:
        json.loads(path.read_text())
    except Exception as exc:  # noqa: BLE001 - operator check reports concise failures.
        return f"invalid JSON: {exc.__class__.__name__}"
    return ""


def check_secret_markers(path: Path) -> list[str]:
    text = path.read_text(errors="replace")
    lowered = text.lower()
    found = []
    for marker in SECRET_MARKERS:
        if marker.lower() in lowered:
            found.append(marker)
    return found


def build_report() -> dict[str, object]:
    repo = root()
    checks: list[dict[str, object]] = []
    for item in REQUIRED_TEMPLATES:
        path = repo / item
        exists = path.is_file()
        checks.append({"ok": exists, "path": item, "check": "exists"})
        if not exists:
            continue
        if path.suffix == ".json":
            error = check_json(path)
            checks.append({"ok": not error, "path": item, "check": "json", "error": error})
        markers = check_secret_markers(path)
        checks.append({"ok": not markers, "path": item, "check": "secret-markers", "markers": markers})

    failures = [check for check in checks if not check["ok"]]
    return {"ok": not failures, "failures": len(failures), "checks": checks}


def print_text(report: dict[str, object]) -> None:
    for check in report["checks"]:  # type: ignore[index]
        status = "PASS" if check["ok"] else "FAIL"  # type: ignore[index]
        print(f"{status} {check['path']} {check['check']}")  # type: ignore[index]


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate Oreo Cloud productization templates.")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    report = build_report()
    if args.json:
        print_json(report)  # type: ignore[arg-type]
    else:
        print_text(report)
    return 0 if report["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
