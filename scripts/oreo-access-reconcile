#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any

from oreo_common import audit, http_status, load_json, now, print_json, regenerate_dashboard, root, save_json


SAFE_CLOUDFLARE_PRIVACY = {"unclassified", "personal", "internal"}


def workload_map() -> dict[str, dict[str, Any]]:
    return {str(item.get("id")): item for item in load_json("workloads.json").get("workloads", [])}


def privacy_for(workload_id: str) -> str:
    data = load_json("privacy.json")
    return str(data.get("workloads", {}).get(workload_id, {}).get("privacy", data.get("defaultPrivacy", "")))


def add(findings: list[dict[str, Any]], level: str, workload_id: str, message: str, **extra: Any) -> None:
    findings.append({"level": level, "workloadId": workload_id, "message": message, **extra})


def cloudflare_evidence_exists() -> bool:
    evidence_dir = root() / "runtime" / "cloudflare-activation"
    return evidence_dir.exists() and any(path.suffix == ".json" for path in evidence_dir.iterdir())


def reconcile(*, offline: bool = False) -> dict[str, Any]:
    access = load_json("access.json")
    routes = load_json("routes.json")
    exposure = load_json("exposure.json")
    workloads = workload_map()
    provider = exposure.get("providers", {}).get("cloudflare", {})
    findings: list[dict[str, Any]] = []

    observed_funnel = bool(routes.get("observed", {}).get("funnel", {}).get("enabled")) or bool(
        exposure.get("providers", {}).get("tailscale", {}).get("funnel", {}).get("observedEnabled")
    )
    if observed_funnel:
        add(findings, "fail", "tailscale", "tracked config still reports Tailscale Funnel enabled")

    for workload_id, item in access.get("workloads", {}).items():
        desired = str(item.get("desired", ""))
        effective = str(item.get("effective", ""))
        route = routes.get("workloadRoutes", {}).get(workload_id, {})
        cloudflare = route.get("cloudflare", {})
        tailnet = route.get("tailnet", {})
        workload = workloads.get(workload_id, {})
        privacy = privacy_for(workload_id)

        if effective == "cloudflare-public":
            add(findings, "fail", workload_id, "cloudflare-public effective access is forbidden in P2")
        if workload.get("kind") == "admin-tool" and effective.startswith("cloudflare"):
            add(findings, "fail", workload_id, "admin tool cannot have Cloudflare effective access")
        if privacy not in SAFE_CLOUDFLARE_PRIVACY and effective.startswith("cloudflare"):
            add(findings, "fail", workload_id, f"{privacy} workload cannot have Cloudflare effective access")

        if effective == "cloudflare-protected":
            hostname = str(cloudflare.get("hostname", ""))
            if not bool(cloudflare.get("enabled")):
                add(findings, "fail", workload_id, "effective cloudflare-protected but route is disabled")
            if cloudflare.get("mode") != "protected":
                add(findings, "fail", workload_id, "effective cloudflare-protected but route mode is not protected")
            if hostname.endswith(".invalid") or not hostname:
                add(findings, "fail", workload_id, "effective cloudflare-protected without a real hostname")
            if not bool(provider.get("enabled")) or not bool(provider.get("provisioned")):
                add(findings, "fail", workload_id, "effective cloudflare-protected but provider is not active")
            if not bool(provider.get("allowNamedTunnels")):
                add(findings, "fail", workload_id, "effective cloudflare-protected but named tunnels are not allowed")
            if not cloudflare_evidence_exists():
                add(findings, "fail", workload_id, "effective cloudflare-protected without activation evidence")

        if effective in {"local", "tailnet", "none"} and bool(cloudflare.get("enabled")) and cloudflare.get("mode") == "protected":
            add(findings, "fail", workload_id, "Cloudflare route enabled while effective access is not Cloudflare")

        if effective == "tailnet" and not bool(tailnet.get("enabled")):
            add(findings, "fail", workload_id, "effective tailnet but tailnet route is disabled")

        local_url = str(item.get("urls", {}).get("local", ""))
        if local_url and effective in {"local", "tailnet"}:
            if offline:
                add(findings, "warn", workload_id, "local probe skipped in offline mode", url=local_url)
            else:
                status, reason = http_status(local_url)
                if status == "fail":
                    add(findings, "warn", workload_id, "local probe failed", url=local_url, reason=reason)
                else:
                    add(findings, "ok", workload_id, "local probe completed", url=local_url, status=status)

        if desired == "cloudflare-protected" and effective != "cloudflare-protected":
            add(findings, "ok", workload_id, "desired Cloudflare protected remains planned until verified activation")

    failures = [item for item in findings if item["level"] == "fail"]
    return {
        "ok": not failures,
        "offline": offline,
        "failures": len(failures),
        "warnings": len([item for item in findings if item["level"] == "warn"]),
        "findings": findings,
    }


def apply_lowering(result: dict[str, Any]) -> dict[str, Any]:
    access = load_json("access.json")
    changed: list[str] = []
    for finding in result["findings"]:
        workload_id = str(finding["workloadId"])
        if finding["level"] != "fail" or workload_id not in access.get("workloads", {}):
            continue
        item = access["workloads"][workload_id]
        if item.get("effective") == "cloudflare-protected":
            item["effective"] = "local"
            item["lastAppliedAt"] = now()
            item["lastError"] = "Lowered by access reconcile after Cloudflare drift."
            changed.append(workload_id)
    if changed:
        save_json("access.json", access)
        regenerate_dashboard(quiet=True)
    for workload_id in changed:
        audit("access.reconcile", workload_id, "lowered", effective="local")
    return {"changed": changed}


def print_text(result: dict[str, Any]) -> None:
    state = "clean" if result["ok"] else "drift detected"
    print(f"Effective access reconcile: {state}")
    for finding in result["findings"]:
        print(f"{finding['level'].upper()} {finding['workloadId']}: {finding['message']}")


def main() -> int:
    parser = argparse.ArgumentParser(description="Detect desired/effective access drift.")
    parser.add_argument("--apply", action="store_true", help="Only lower Cloudflare effective access after drift.")
    parser.add_argument("--offline", action="store_true", help="Skip live HTTP probes.")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    result = reconcile(offline=args.offline)
    if args.apply:
        result["apply"] = apply_lowering(result)
    if args.json:
        print_json(result)
    else:
        print_text(result)
    return 0 if result["ok"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
