#!/usr/bin/env python3
"""Read-only scan for Docker Compose projects not yet tracked as workloads.

Does not mutate config, restart services, or change access/exposure state.
"""
from __future__ import annotations

import argparse
import json
import shutil
import subprocess

from argus_common import audit, now, print_json, root, workloads


def known_compose_projects() -> set[str]:
    known = set()
    for workload in workloads():
        project = workload.get("runtime", {}).get("composeProject") or workload.get("id")
        if project:
            known.add(str(project))
    return known


def running_compose_projects() -> list[str]:
    if not shutil.which("docker"):
        return []
    result = subprocess.run(
        ["docker", "ps", "--format", '{{.Label "com.docker.compose.project"}}'],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    projects = {line.strip() for line in result.stdout.splitlines() if line.strip()}
    return sorted(projects)


def main() -> int:
    parser = argparse.ArgumentParser(description="Find running Compose projects not yet tracked in config/workloads.json.")
    parser.add_argument("--json", action="store_true", help="print machine-readable output")
    args = parser.parse_args()

    known = known_compose_projects()
    running = running_compose_projects()
    new = [project for project in running if project not in known]

    report = {
        "timestamp": now(),
        "knownWorkloadCount": len(known),
        "runningComposeProjects": running,
        "newComposeProjects": new,
    }

    log_dir = root() / "runtime" / "discovery"
    log_dir.mkdir(parents=True, exist_ok=True)
    (log_dir / "latest.json").write_text(json.dumps(report, indent=2, sort_keys=True) + "\n")
    audit("workload.discover", "platform", "ok", newComposeProjects=new)

    if args.json:
        print_json(report)
    else:
        if new:
            print("New compose projects not yet tracked:")
            for project in new:
                print(f"  - {project}")
            print("Review each candidate, then run argus-workload-add to register it.")
        else:
            print("No new compose projects found.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
