#!/usr/bin/env python3
"""Capture the read-only Argus M0 legacy-runtime inventory."""

from __future__ import annotations

import argparse

from argus_legacy import collect_inventory, write_inventory


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Capture secret-safe listeners, containers, mounts, networks, volumes, routes, and firewall evidence."
    )
    parser.add_argument("--json", action="store_true", help="print the normalized evidence document")
    parser.add_argument("--no-write", action="store_true", help="do not persist evidence under runtime/argus")
    args = parser.parse_args()

    payload = collect_inventory()
    path = None if args.no_write else write_inventory(payload)
    if args.json:
        import json

        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"Argus M0 inventory complete: {payload['complete']}")
        print(f"containers: {len(payload['containers'])}")
        print(f"listeners: {len(payload['listeners'])}")
        print(f"networks: {len(payload['networks'])}")
        print(f"volumes: {len(payload['volumes'])}")
        print(f"blocking findings: {len(payload['blockingFindings'])}")
        print(f"evidence gaps: {len(payload['evidenceGaps'])}")
        if path:
            print(f"private evidence: {path}")
    return 0 if payload["complete"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
