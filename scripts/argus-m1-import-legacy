#!/usr/bin/env python3
"""Create a shadow Argus SQLite store from quarantined legacy workload metadata."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from argus_state import SQLiteRepository, legacy_workload_snapshot


ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    parser = argparse.ArgumentParser(description="Import the legacy workload registry into a shadow Argus SQLite store.")
    parser.add_argument("--output", type=Path, default=ROOT / "runtime" / "argus" / "entity-store.sqlite3")
    args = parser.parse_args()
    workloads = json.loads((ROOT / "config" / "workloads.json").read_text())["workloads"]
    classifications = json.loads((ROOT / "config" / "argus" / "legacy-classification.json").read_text())["workloads"]
    snapshot = legacy_workload_snapshot(workloads, classifications)
    repository = SQLiteRepository(args.output)
    repository.import_snapshot(snapshot)
    if not repository.semantic_parity(snapshot):
        raise SystemExit("shadow SQLite import failed semantic parity")
    print(f"Imported {len(snapshot)} quarantined legacy entities into {args.output}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
