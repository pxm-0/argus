#!/usr/bin/env python3
"""Export or independently verify a secret-safe Argus M1 audit checkpoint."""

from __future__ import annotations

import argparse
import json
from pathlib import Path

from argus_legacy import write_inventory
from argus_state import AuditLedger, verify_audit_checkpoint


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_LEDGER = ROOT / "runtime" / "argus" / "audit.sqlite3"
DEFAULT_OUTPUT = ROOT / "runtime" / "argus" / "audit-checkpoint.json"


def load_checkpoint(path: Path) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise SystemExit(f"invalid checkpoint: {path}") from exc
    if not isinstance(value, dict):
        raise SystemExit("invalid checkpoint: expected an object")
    return value


def main() -> int:
    parser = argparse.ArgumentParser(description="Export or verify a transportable M1 audit checkpoint.")
    parser.add_argument("--ledger", type=Path, default=DEFAULT_LEDGER)
    parser.add_argument("--output", type=Path, default=DEFAULT_OUTPUT)
    parser.add_argument("--verify", type=Path, help="verify a copied checkpoint without opening a ledger")
    args = parser.parse_args()
    if args.verify:
        checkpoint = load_checkpoint(args.verify)
        if not verify_audit_checkpoint(checkpoint):
            raise SystemExit("checkpoint verification failed")
        print(f"Argus M1 audit checkpoint verified: sequence {checkpoint['sequence']}")
        print(f"checkpoint hash: {checkpoint['checkpointHash']}")
        return 0
    if not args.ledger.is_file():
        raise SystemExit(f"missing audit ledger: {args.ledger}")
    ledger = AuditLedger(args.ledger)
    if not ledger.verify():
        raise SystemExit("refusing to export a tampered audit ledger")
    checkpoint = ledger.checkpoint()
    if checkpoint["sequence"] < 1:
        raise SystemExit("refusing to anchor an empty audit ledger")
    write_inventory(checkpoint, args.output)
    print(f"Argus M1 audit checkpoint exported: sequence {checkpoint['sequence']}")
    print(f"checkpoint hash: {checkpoint['checkpointHash']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
