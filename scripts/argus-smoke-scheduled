#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import re
import subprocess
from pathlib import Path

from argus_common import audit, now, root


SUMMARY = re.compile(r"Smoke summary: (?P<failures>\d+) failure\(s\), (?P<warnings>\d+) warning\(s\)")


def parse_summary(output: str) -> tuple[int, int]:
    match = SUMMARY.search(output)
    if not match:
        return -1, -1
    return int(match.group("failures")), int(match.group("warnings"))


def main() -> int:
    parser = argparse.ArgumentParser(description="Run scheduled Argus smoke and write local status evidence.")
    parser.add_argument("--offline", action="store_true", help="skip live server checks")
    parser.add_argument("--log-dir", type=Path, default=root() / "runtime" / "smoke")
    args = parser.parse_args()

    command = [str(root() / "scripts" / "smoke-test")]
    if args.offline:
        command.append("--offline")
    result = subprocess.run(command, cwd=root(), text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, check=False)
    failures, warnings = parse_summary(result.stdout)
    ok = result.returncode == 0 and failures == 0

    args.log_dir.mkdir(parents=True, exist_ok=True)
    (args.log_dir / "latest.log").write_text(result.stdout)
    status = {
        "ok": ok,
        "timestamp": now(),
        "command": command,
        "exitCode": result.returncode,
        "failures": failures,
        "warnings": warnings,
        "log": str(args.log_dir / "latest.log"),
    }
    (args.log_dir / "latest.json").write_text(json.dumps(status, indent=2, sort_keys=True) + "\n")
    audit("smoke.scheduled", "platform", "ok" if ok else "failed", exitCode=result.returncode, failures=failures, warnings=warnings)
    print(json.dumps(status, indent=2, sort_keys=True))
    return 0 if ok else 1


if __name__ == "__main__":
    raise SystemExit(main())
