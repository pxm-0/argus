      "runtime": {
        "type": "docker-compose",
        "composePath": "/srv/argus/workloads/intake-os/source/docker-compose.server.yml",
        "composeProject": "intake-os",
        "service": ""
      },
      "network": {
        "localUrl": "http://127.0.0.1:8080",
        "internalPort": 8080
      },
      "health": {
        "enabled": true,
        "url": "http://127.0.0.1:8080/health",
